# Copy to .env.local and fill in your values
CLICKUP_TOKEN=pk_your_token_here

# Shared access PIN — required to open the app (stored in httpOnly cookie for 30 days)
ACCESS_PIN=your_access_pin_here

# Local dev only — bypass access gate when ACCESS_PIN is set
# ACCESS_DISABLED=true

# Admin PIN for unlocking edit access on the mindmap (separate from ACCESS_PIN)
ADMIN_PIN=1234

# Legacy client hint — prefer ADMIN_PIN above
NEXT_PUBLIC_ADMIN_PIN=1234
